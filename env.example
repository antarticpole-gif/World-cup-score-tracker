# Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# The numeric ID of the channel to post results into
# (Enable Developer Mode in Discord, then right-click the channel -> Copy ID)
CHANNEL_ID=123456789012345678

# API-Football key (from https://www.api-football.com/ or via RapidAPI)
API_FOOTBALL_KEY=your_api_football_key_here

# League ID for the FIFA World Cup in API-Football (1 = World Cup)
WORLD_CUP_LEAGUE_ID=1

# Season year for the 2026 World Cup
WORLD_CUP_SEASON=2026

# --- Schedule-aware polling settings ---

# How often (seconds) to check for finished matches WHILE a match is live
# or recently finished (e.g. 120 = every 2 minutes)
LIVE_POLL_INTERVAL_SECONDS=120

# How often (seconds) to check whether it's match time yet when idle
# (e.g. 1800 = every 30 minutes)
IDLE_CHECK_INTERVAL_SECONDS=1800

# How many minutes after kickoff to keep polling for a result
# (covers 90 mins + stoppage + extra time + penalties for knockout games)
MATCH_WINDOW_MINUTES=150

# How many minutes before kickoff to start polling (in case of early starts)
PRE_MATCH_BUFFER_MINUTES=5
